{
  "name": "brandfolder",
  "version": "2.1.0",
  "engines": {
    "sketch": ">=3.0"
  },
  "skpm": {
    "name": "Brandfolder",
    "manifest": "src/manifest.json",
    "main": "brandfolder.sketchplugin",
    "assets": [
      "assets/**/*"
    ]
  },
  "scripts": {
    "build": "skpm-build",
    "watch": "skpm-build --watch",
    "start": "skpm-build --watch --run",
    "postinstall": "npm run build && skpm-link"
  },
  "devDependencies": {
    "@babel/plugin-transform-runtime": "^7.25.9",
    "@skpm/builder": "^0.9.5"
  },
  "dependencies": {
    "@babel/runtime": "^7.26.10",
    "jwt-decode": "^2.2.0",
    "sketch-module-web-view": "^2.1.7"
  },
  "description": "Speed up your design workflow by accessing your Brandfolder asset library right from Sketch",
  "main": "index.js",
  "keywords": [],
  "author": "Brandfolder",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git@github.com:brandfolder/sketch-plugin-brandfolder.git"
  },
  "volta": {
    "node": "20.15.1"
  },
  "overrides": {
    "@babel/core": "^7.26.10",
    "@babel/helpers": "^7.26.10",
    "pbkdf2": "^3.1.3",
    "cipher-base": "^1.0.5",
    "sha.js": "^2.4.12"
  }
}
